{
  "name": "@aetherien/svelte-i18n",
  "version": "4.0.22",
  "description": "Internationalization library for Svelte",
  "keywords": [
    "svelte",
    "i18n",
    "internationalization",
    "localization",
    "translation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aetherien/svelte-i18n.git"
  },
  "license": "MIT",
  "author": "Christian Kaisermann <christian@kaisermann.me>. Modified by Aetherien BV.",
  "type": "module",
  "exports": {
    "types": "./dist/runtime.d.ts",
    "default": "./dist/runtime.js"
  },
  "main": "dist/runtime.js",
  "types": "dist/runtime.d.ts",
  "bin": {
    "svelte-i18n": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "rollup -c",
    "clean": "rm -rf dist/",
    "dev": "rollup -c -w",
    "format": "prettier --loglevel silent --write \"{src,test}/**/*.ts\"",
    "lint": "npm audit && npx sort-package-json --check && eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "npm audit fix && npm pkg fix && npx sort-package-json && eslint \"{src,test}/**/*.ts\" --fix",
    "prepare": "husky",
    "prepublishOnly": "pnpm test && pnpm build && publint",
    "release": " git add package.json && git commit -m \"chore(release): v$npm_package_version :tada:\"",
    "test": "npm run lint && cross-env NODE_ICU_DATA=node_modules/full-icu jest",
    "test:ci": "pnpm test",
    "version": "conventional-changelog -p angular -i CHANGELOG.md -s -r 1 && git add CHANGELOG.md",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "cli-color": "^2.0.4",
    "deepmerge": "^4.3.1",
    "estree-walker": "3.0.3",
    "intl-messageformat": "^11.2.1",
    "sade": "^1.8.1",
    "tiny-glob": "^0.2.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@kiwi/prettier-config": "^4.2.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@types/cli-color": "^2.0.6",
    "@types/dlv": "^1.1.5",
    "@types/estree": "1.0.8",
    "@types/intl": "^1.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/sade": "^1.8.0",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "full-icu": "^1.5.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-sonar-reporter": "^2.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.3.18",
    "rollup": "^4.60.2",
    "rollup-plugin-auto-external": "^2.0.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "sort-package-json": "^3.6.1",
    "svelte": "^5.55.4",
    "svelte-preprocess": "^5.0.4",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "peerDependencies": {
    "svelte": "^3 || ^4 || ^5"
  },
  "engines": {
    "node": ">= 16"
  },
  "volta": {
    "node": "16.14.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}